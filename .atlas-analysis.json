  "keyFeatures": [
    "JWT-based authentication with OAuth2 password flow",
    "User registration and login endpoints",
    "Role-based access control (Admin/Client)",
    "Complete CRUD operations for user management",
    "Clean Architecture with domain-driven design",
    "Async MongoDB integration with Motor",
    "Password hashing with passlib",
    "Dependency injection for repositories and validation"
  ],
  "publicApiSurface": [
    "POST /users/login - Authenticate user and receive JWT token",
    "POST /users/register - Register new user account",
    "GET /users - List all users (authenticated)",
    "GET /users/query - Query users by field (authenticated)",
    "GET /users/{id} - Get user by ID (authenticated)",
    "PUT /users/{id} - Update user information",
    "PATCH /users/{id} - Update user password",
    "DELETE /users/{id} - Delete user (authenticated)",
    "User (domain entity)",
    "UserCreate (schema)",
    "UserUpdate (schema)",
    "UserResponse (schema)",
    "RoleUser (value object)",
    "RegisterUserUseCase",
    "LoginUserUseCase",
    "UpdateUserUseCase",
    "DeleteUserUseCase",
    "GetUserByQueryUseCase",
    "ListUsersUseCase"
  ]
